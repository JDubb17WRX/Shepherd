{
    auto_https off
    frankenphp
    order php_server before file_server
}

:8080 {
    root * /var/www/html
    encode zstd gzip

    header {
        X-Frame-Options "SAMEORIGIN"
        Content-Security-Policy "frame-ancestors 'self'"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    @dotfiles path_regexp hidden ^/shepherd/(?:.*/)?\.
    @protected path /shepherd/Include/* /shepherd/logs/* /shepherd/tmp_attach/*
    # Uploaded person/family photos must be served through authenticated API routes.
    # Caddy does not honor the deny rules in the directories' .htaccess files.
    # See: GHSA-r286-h493-ppwj
    @privateMedia path_regexp privateMedia (?i)^/shepherd/Images/(?:Person|Family)(?:/|$)
    @pluginPhp path_regexp pluginphp ^/shepherd/plugins/(community|core)/.+\.(php|phar|phtml|pht|php[3-9])$

    # `route` preserves literal handler order. Without it, Caddy's directive
    # sorting places `handle` before top-level `respond` directives.
    route {
        handle /shepherd/healthz {
            respond 200
        }

        respond @dotfiles 404
        respond @protected 404
        respond @privateMedia 404
        respond @pluginPhp 404

        handle /shepherd/session/* {
            try_files {path} /shepherd/session/index.php
            php_server
        }
        handle /shepherd/api/* {
            try_files {path} /shepherd/api/index.php
            php_server
        }
        handle /shepherd/v2/* {
            try_files {path} /shepherd/v2/index.php
            php_server
        }
        handle /shepherd/admin/* {
            try_files {path} /shepherd/admin/index.php
            php_server
        }
        handle /shepherd/finance/* {
            try_files {path} /shepherd/finance/index.php
            php_server
        }
        handle /shepherd/kiosk/* {
            try_files {path} /shepherd/kiosk/index.php
            php_server
        }
        handle /shepherd/plugins/* {
            try_files {path} /shepherd/plugins/index.php
            php_server
        }
        handle /shepherd/external/* {
            try_files {path} /shepherd/external/index.php
            php_server
        }
        handle /shepherd/setup/* {
            try_files {path} /shepherd/setup/index.php
            php_server
        }
        handle /shepherd/* {
            try_files {path} {path}/ /shepherd/index.php
            php_server
        }
        respond 404
    }
}
